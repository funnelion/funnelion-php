{
    "name": "funnelion/sdk",
    "description": "Official PHP SDK for Funnelion server-side call tracking.",
    "type": "library",
    "license": "MIT",
    "keywords": ["funnelion", "call-tracking", "sdk", "tracking", "server-side", "attribution"],
    "homepage": "https://github.com/funnelion/funnelion-php",
    "support": {
        "issues": "https://github.com/funnelion/funnelion-php/issues",
        "source": "https://github.com/funnelion/funnelion-php"
    },
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Funnelion\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Funnelion\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
